{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Winbull Client Configuration",
  "description": "Schema for global_configs.php — all per-client configuration fields for the Winbull trading platform.",
  "type": "object",
  "properties": {
    "identity": {
      "title": "Client Identity",
      "type": "object",
      "properties": {
        "client": {
          "type": "string",
          "title": "Client Slug",
          "description": "Unique lowercase identifier used for DB names, socket event prefixes, file paths. Must be alphanumeric + underscores.",
          "pattern": "^[a-z][a-z0-9_]*$",
          "examples": ["maharaj", "sriram_gold", "laxmi_bullion"]
        },
        "web_title": {
          "type": "string",
          "title": "Website Title",
          "description": "Display name shown in browser title bar and headers",
          "examples": ["Maharaj Gold Smith"]
        },
        "web_copyright": {
          "type": "string",
          "title": "Copyright Text",
          "description": "Footer copyright line",
          "examples": ["© 2026 Maharaj Gold Smith. All Rights Reserved"]
        },
        "timezone": {
          "type": "string",
          "title": "Timezone",
          "default": "Asia/Kolkata",
          "enum": ["Asia/Kolkata", "Asia/Dubai", "Asia/Singapore", "UTC"]
        }
      },
      "required": ["client", "web_title"]
    },

    "urls": {
      "title": "Base URLs",
      "type": "object",
      "properties": {
        "web_base_url": {
          "type": "string",
          "format": "uri",
          "title": "Website URL",
          "description": "Public website URL (with trailing slash)",
          "examples": ["http://www.maharajgoldsmith.com/"]
        },
        "app_base_url": {
          "type": "string",
          "format": "uri",
          "title": "Mobile API URL",
          "description": "Base URL for mobile API endpoints",
          "examples": ["http://www.maharajgoldsmith.com/mobileapi/"]
        },
        "admin_base_url": {
          "type": "string",
          "format": "uri",
          "title": "Admin Panel URL",
          "examples": ["http://www.maharajgoldsmith.com/admin/"]
        }
      },
      "required": ["web_base_url"]
    },

    "database": {
      "title": "Database Credentials",
      "type": "object",
      "properties": {
        "hostname": {
          "type": "string",
          "title": "DB Hostname",
          "description": "MySQL/RDS endpoint",
          "examples": ["database-1.cb86ugsw4aax.ap-south-1.rds.amazonaws.com", "localhost"]
        },
        "username": {
          "type": "string",
          "title": "DB Username",
          "examples": ["admin"]
        },
        "password": {
          "type": "string",
          "title": "DB Password",
          "format": "password"
        },
        "database": {
          "type": "string",
          "title": "DB Name",
          "description": "Usually matches the client slug",
          "examples": ["maharaj"]
        }
      },
      "required": ["hostname", "username", "password", "database"]
    },

    "versions": {
      "title": "App Versions",
      "type": "object",
      "properties": {
        "web_version": {
          "type": "string",
          "title": "Web Version",
          "default": "1.0.1"
        },
        "admin_web_version": {
          "type": "string",
          "title": "Admin Version",
          "default": "4.2.0"
        },
        "VERSIONNAME": {
          "type": "string",
          "title": "Android Version",
          "default": "1.0.0"
        },
        "NEWVERSIONNAME": {
          "type": "string",
          "title": "Android New Version",
          "default": "1.0.0"
        },
        "CURRENTVERSIONNAME": {
          "type": "string",
          "title": "Android Current Version",
          "default": "1.0.0"
        },
        "IOSVERSIONNAME": {
          "type": "string",
          "title": "iOS Version",
          "default": "1.0.0"
        },
        "IOSNEWVERSIONNAME": {
          "type": "string",
          "title": "iOS New Version",
          "default": "1.0.0"
        },
        "IOSCURRENTVERSIONNAME": {
          "type": "string",
          "title": "iOS Current Version",
          "default": "1.0.0"
        }
      }
    },

    "flags": {
      "title": "Feature Flags",
      "type": "object",
      "properties": {
        "IOS_OTR": {
          "type": "integer",
          "title": "iOS OTR Flag",
          "enum": [0, 1],
          "default": 0
        },
        "ANDROID_OTR": {
          "type": "integer",
          "title": "Android OTR Flag",
          "enum": [0, 1],
          "default": 0
        },
        "IOS_USERDELETE": {
          "type": "integer",
          "title": "iOS User Delete",
          "enum": [0, 1],
          "default": 0
        },
        "ANDROID_USERDELETE": {
          "type": "integer",
          "title": "Android User Delete",
          "enum": [0, 1],
          "default": 0
        },
        "app_header_chk": {
          "type": "integer",
          "title": "App Header Check",
          "enum": [0, 1],
          "default": 0
        },
        "polling": {
          "type": "integer",
          "title": "Polling Enabled",
          "description": "0 = off, 1 = on",
          "enum": [0, 1],
          "default": 1
        }
      }
    },

    "rateFeed": {
      "title": "Rate Feed Configuration",
      "type": "object",
      "properties": {
        "bcrateType": {
          "type": "integer",
          "title": "Web Rate Type",
          "description": "0 = normal PHP, 1 = encryption PHP, 2 = websocket",
          "enum": [0, 1, 2],
          "default": 2
        },
        "rpRateType": {
          "type": "integer",
          "title": "RPanel Rate Type",
          "description": "0 = PHP encryption, 1 = websocket",
          "enum": [0, 1],
          "default": 0
        },
        "rateFeed": {
          "type": "integer",
          "title": "App Rate Feed",
          "description": "0 = encryption PHP, 1 = broadcast rate, 2 = text file, 3 = Web socket, 4 = Native Socket",
          "enum": [0, 1, 2, 3, 4],
          "default": 4
        },
        "websocket_type": {
          "type": "integer",
          "title": "WebSocket Type",
          "description": "1 = socket.io, 2 = Native socket",
          "enum": [1, 2],
          "default": 2
        }
      }
    },

    "socket": {
      "title": "Socket & Real-time Config",
      "type": "object",
      "properties": {
        "socket_base_url": {
          "type": "string",
          "format": "uri",
          "title": "Socket Base URL"
        },
        "rate_socketurl": {
          "type": "string",
          "format": "uri",
          "title": "Rate Socket URL",
          "description": "Socket.io endpoint for rate streaming"
        },
        "nativesocketurl": {
          "type": "string",
          "title": "Native WebSocket URL",
          "description": "ws:// or wss:// URL for native WebSocket",
          "examples": ["ws://www.maharajgoldsmith.com/ws"]
        },
        "ratesocketurl": {
          "type": "string",
          "format": "uri",
          "title": "Rate Socket URL (alt)"
        }
      }
    },

    "lightstreamer": {
      "title": "Lightstreamer Connection",
      "type": "object",
      "properties": {
        "lsrateurl": {
          "type": "string",
          "title": "LS Server URL",
          "examples": ["http://72.52.178.11:8080"]
        },
        "lsrateadapter": {
          "type": "string",
          "title": "LS Adapter",
          "default": "WLSTOCKLIST_REMOTE"
        },
        "lsrateprovider": {
          "type": "string",
          "title": "LS Provider",
          "default": "WLQUOTE_ADAPTER"
        },
        "lsrateusername": {
          "type": "string",
          "title": "LS Username (Web)",
          "examples": ["lmxwinbullliteapp"]
        },
        "lsrateusernameapp": {
          "type": "string",
          "title": "LS Username (App)",
          "examples": ["lmxwinbullliteapp"]
        }
      }
    },

    "broadcast": {
      "title": "Broadcast Rate Details",
      "type": "object",
      "properties": {
        "bcclient": {
          "type": "string",
          "title": "Broadcast Client ID",
          "description": "Usually matches the client slug"
        },
        "bcusername": {
          "type": "string",
          "title": "Broadcast Username"
        },
        "bcpassword": {
          "type": "string",
          "title": "Broadcast Password",
          "format": "password"
        },
        "bcupdatetime": {
          "type": "string",
          "title": "Broadcast Update Interval (ms)",
          "default": "800"
        }
      }
    },

    "encryption": {
      "title": "Encryption Settings",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "title": "Encryption Key",
          "description": "30-char key used for rate data encryption",
          "minLength": 20,
          "format": "password"
        },
        "path": {
          "type": "string",
          "title": "Encrypted File Path",
          "description": "Absolute server path to the .enc file",
          "examples": ["/var/www/html/maharaj/client/maharaj.enc"]
        }
      }
    },

    "notifications": {
      "title": "Push Notification Settings",
      "type": "object",
      "properties": {
        "notification_title": {
          "type": "string",
          "title": "Notification Title",
          "examples": ["Maharaj Bullion"]
        },
        "notification_subtitle": {
          "type": "string",
          "title": "Notification Subtitle"
        },
        "app_id": {
          "type": "string",
          "title": "OneSignal App ID (Client)",
          "format": "uuid"
        },
        "onesignalauth": {
          "type": "string",
          "title": "OneSignal API Key (Client)",
          "format": "password"
        },
        "notification_title_admin": {
          "type": "string",
          "title": "Admin Notification Title"
        },
        "notification_subtitle_admin": {
          "type": "string",
          "title": "Admin Notification Subtitle"
        },
        "app_id_admin": {
          "type": "string",
          "title": "OneSignal App ID (Admin)"
        },
        "onesingalapi_admin": {
          "type": "string",
          "title": "OneSignal API Key (Admin)",
          "format": "password"
        }
      }
    },

    "whatsapp": {
      "title": "WhatsApp Configuration",
      "type": "object",
      "properties": {
        "whatsappurl": {
          "type": "string",
          "format": "uri",
          "title": "WhatsApp API URL"
        },
        "instanceid": {
          "type": "string",
          "title": "WhatsApp Instance ID"
        }
      }
    },

    "mobileApps": {
      "title": "Mobile App Store URLs",
      "type": "object",
      "properties": {
        "androidUrl": {
          "type": "string",
          "format": "uri",
          "title": "Play Store URL"
        },
        "iosUrl": {
          "type": "string",
          "format": "uri",
          "title": "App Store URL"
        }
      }
    },

    "email": {
      "title": "Email Configuration",
      "type": "object",
      "properties": {
        "enqFromId": {
          "type": "string",
          "format": "email",
          "title": "Enquiry From Email"
        },
        "enqToId": {
          "type": "string",
          "format": "email",
          "title": "Enquiry To Email"
        },
        "enqCCId": {
          "type": "string",
          "title": "Enquiry CC Emails"
        }
      }
    },

    "hedge": {
      "title": "Motilal Oswal Hedge Config",
      "type": "object",
      "properties": {
        "clientcode": { "type": "string", "title": "Client Code" },
        "hedge_password": { "type": "string", "title": "Hedge Password", "format": "password" },
        "secret_key": { "type": "string", "title": "Secret Key", "format": "password" },
        "twoFA": { "type": "string", "title": "2FA Code" },
        "ApiKey": { "type": "string", "title": "API Key", "format": "password" },
        "authapi": { "type": "string", "title": "Auth API URL" },
        "placeorder": { "type": "string", "title": "Place Order API URL" },
        "gold_mini_symbol": { "type": "string", "title": "Gold Mini Symbol" },
        "gold_micro_symbol": { "type": "string", "title": "Gold Micro Symbol" }
      }
    },

    "display": {
      "title": "Display Settings",
      "type": "object",
      "properties": {
        "bookno_for_mobile": {
          "type": "string",
          "title": "Book Number HTML",
          "description": "HTML snippet for booking phone numbers"
        }
      }
    },

    "cortexo": {
      "title": "Cortexo Error Tracking",
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string",
          "title": "Cortexo SDK API Key",
          "description": "Project SDK key from Cortexo dashboard (Projects → SDK Key)",
          "format": "password",
          "examples": ["proj_abc123def456"]
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "title": "Cortexo Ingest URL",
          "description": "Error ingest API endpoint",
          "default": "http://localhost:4000/v1/ingest/error"
        },
        "environment": {
          "type": "string",
          "title": "Environment",
          "default": "production",
          "enum": ["production", "staging", "development"]
        },
        "enabled": {
          "type": "string",
          "title": "SDK Enabled",
          "default": "true",
          "enum": ["true", "false"]
        }
      }
    }
  },
  "required": ["identity", "urls", "database"]
}
