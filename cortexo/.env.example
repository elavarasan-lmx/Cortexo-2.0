# ===================================
# Cortexo — Environment Variables
# Copy to .env and fill in your values
# ===================================

# --- Database (PostgreSQL 16) ---
DATABASE_URL="postgresql://cortexo:YOUR_PASSWORD@localhost:5432/cortexo"
DB_HOST="127.0.0.1"
DB_PORT=5432
DB_USER="cortexo"
DB_PASSWORD="YOUR_PASSWORD"
DB_NAME="cortexo"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- NextAuth.js ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here-at-least-32-chars"

# --- OAuth Providers ---
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY=""

# --- AI Providers (Phase 4+) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Fastify API Server ---
API_PORT=4000
API_HOST="0.0.0.0"
JWT_SECRET="generate-a-random-secret-here-at-least-32-chars"

# --- Dev Auth Bypass (DEVELOPMENT ONLY — never enable in production) ---
UNSAFE_DEV_AUTH="false"

# --- App Config ---
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
AUTH_SECRET="generate-a-random-secret-here-at-least-32-chars"

